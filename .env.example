# Copy this file to `.env` and fill in your values.
# Then run:  source .env && python server.py
# On Windows PowerShell, see README.md.

# REQUIRED — the slug in your Plane URL: https://app.plane.so/<this-part>/projects/...
export PLANE_WORKSPACE_SLUG="plane"

# The WEB project UUID. Change if pointing at a different project.
export PLANE_PROJECT_ID="02c3e1d5-d7e2-401d-a773-45ecba45d745"

# Optional overrides
export PORT="8765"
export WINDOW_DAYS="183"
export PLANE_API_BASE="https://api.plane.so/api/v1"

# ---- Auth (PAT login) ----
# When SESSION_SECRET is set, the dashboard requires each user to sign in by
# pasting their own Plane Personal Access Token at /login. That PAT is then
# used for all their Plane API requests, so each user only sees data they
# have Plane permission to see.
#
# Generate a random secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
export SESSION_SECRET=""

# Comma-separated list of email domains permitted to sign in.
export ALLOWED_EMAIL_DOMAINS="plane.so"

# Session lifetime in seconds (default: 12 hours).
export SESSION_TTL_SECONDS="43200"

# ---- Fallback shared PAT (optional) ----
# Only used when SESSION_SECRET is empty (auth disabled), e.g. single-user
# local dev. Leave blank if you're using PAT login above.
#   Get a PAT at https://app.plane.so/profile/settings (Personal Access Tokens).
export PLANE_API_KEY=""
